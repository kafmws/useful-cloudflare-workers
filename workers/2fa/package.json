{
  "name": "2fa",
  "version": "1.0.0",
  "description": "TOTP/HOTP API — runs on Cloudflare Workers or Node.js",
  "type": "module",
  "scripts": {
    "dev": "node --import tsx/esm src/node-server.ts",
    "dev:cf": "wrangler dev",
    "build": "tsc --outDir dist",
    "build:cf": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240502.0",
    "@types/node": "^20.14.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.7",
    "wrangler": "^4.95.0"
  }
}
