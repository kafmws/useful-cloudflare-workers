# ── Required ──────────────────────────────────────────────────────────────────
# Master key — full access (add/delete keys + generate OTPs)
ADMIN_API_KEY=change-me-to-a-strong-random-secret

# ── Optional ──────────────────────────────────────────────────────────────────
# Comma-separated read-only keys (OTP generation only)
READONLY_API_KEYS=

# Path to the keychain JSON file (Node only; CF uses KV)
KEYCHAIN_PATH=./data/keychain.json

# Path to persistent JSONL request logs (Node only; CF uses platform logs)
LOG_FILE=./data/2fa-worker.log

# ── Server (Node only) ────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Max requests per window per API key (0 = disabled)
RATE_LIMIT_MAX=60
# Window size in seconds
RATE_LIMIT_TTL=60

# ── CORS ──────────────────────────────────────────────────────────────────────
# * means all origins; or comma-separated list
CORS_ORIGINS=*

# ── App ───────────────────────────────────────────────────────────────────────
APP_VERSION=1.0.0
